{
  "name": "@waylay/react-filter-box",
  "version": "3.5.0-beta.0",
  "description": "Conditional filter supports OR/AND, bracket, Highlighting, Autocomplete, and high extensibility   ",
  "scripts": {
    "lint": "tslint ./src/**/*.tsx?",
    "test": "vitest run",
    "build:bundle": "rollup -c rollup.component.config.js",
    "build:types": "node ./node_modules/typescript/bin/tsc -p tsconfig.build.json --pretty false",
    "component-package": "rm -rf lib && yarn run build:bundle && yarn run build:types && yarn run less",
    "less": "lessc ./src/ReactFilterBox.less ./lib/react-filter-box.css",
    "prepublish": "yarn run component-package",
    "version": "conventional-changelog -i CHANGELOG.md -s -r 0 -p @spyke/conventional-changelog-preset && git add CHANGELOG.md"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nhabuiduc/react-filter-box"
  },
  "main": "lib/react-filter-box.js",
  "types": "./lib/src/ReactFilterBox.d.ts",
  "keywords": [
    "react-component",
    "react",
    "reactjs",
    "filter",
    "condition",
    "search",
    "hmr",
    "live",
    "edit",
    "webpack"
  ],
  "author": "nha bui duc (http://github.com/nhabuiduc)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nhabuiduc/react-filter-box"
  },
  "homepage": "",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@1.22.22",
  "devDependencies": {
    "@babel/cli": "^7.27.2",
    "@babel/core": "^7.27.3",
    "@babel/preset-env": "^7.27.2",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@rollup/plugin-commonjs": "^28.0.8",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.1.4",
    "@spyke/conventional-changelog-preset": "^1.0.5",
    "@types/chai": "^4.3.4",
    "@types/codemirror": "^0.0.70",
    "@types/enzyme": "^3.1.15",
    "@types/fixed-data-table": "^0.6.34",
    "@types/lodash": "^4.14.190",
    "@types/pegjs": "^0.10.1",
    "@types/react": "^18.0.25",
    "@types/react-dom": "^18.0.9",
    "@types/sinon": "^10.0.13",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "chai": "^4.3.7",
    "conventional-changelog": "^7.2.0",
    "enzyme": "^3.11.0",
    "fixed-data-table": "^0.6.5",
    "ignore-styles": "^5.0.1",
    "jsdom": "^28.1.0",
    "jsdom-global": "^3.0.2",
    "less": "^4.2.0",
    "postcss": "^8.5.10",
    "react-day-picker": "^8.3.7",
    "react-test-renderer": "^18.2.0",
    "rollup": "^4.59.0",
    "rollup-plugin-postcss": "^4.0.2",
    "sinon": "^15.2.0",
    "ts-node": "^10.9.1",
    "tslib": "^2.8.1",
    "tslint": "^6.1.3",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "codemirror": "^5.42.0",
